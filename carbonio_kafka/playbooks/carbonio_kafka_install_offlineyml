---
- hosts: all
  order: inventory
  gather_facts: yes
  roles:
     - ../roles/pre_installation_checks

- hosts: kafka
  order: inventory
  gather_facts: yes
  vars:
      offline: true
  roles:
     - ../roles/install_kafka

- hosts: applicationServers
  order: inventory
  gather_facts: yes
  roles:
     - ../roles/configure_kafka_mailbox